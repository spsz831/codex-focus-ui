{
  "name": "codex-focus-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Focus-first companion UI for Codex CLI sessions.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:cli": "node apps/cli/src/index.js",
    "dev:viewer": "node apps/viewer/src/index.js",
    "demo:capture": "node apps/cli/src/index.js demo",
    "proxy:codex-version": "node apps/cli/src/index.js proxy -- codex --version",
    "doctor": "node apps/cli/src/index.js doctor",
    "start": "node apps/viewer/src/index.js",
    "test:smoke": "node scripts/smoke-test.js",
    "dev": "npm run dev:cli"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
