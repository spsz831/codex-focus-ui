{
  "name": "codex-focus-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Focus-first companion UI for Codex CLI sessions.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:cli": "node apps/cli/src/index.js",
    "dev:viewer": "node apps/viewer/src/index.js",
    "demo:capture": "node apps/cli/src/index.js demo",
    "proxy:codex-version": "node apps/cli/src/index.js proxy -- codex --version",
    "doctor": "node apps/cli/src/index.js doctor",
    "start": "node apps/viewer/src/index.js",
    "test:smoke": "node scripts/smoke-test.js",
    "oneclick": "powershell -ExecutionPolicy Bypass -File scripts/cfu.ps1 start",
    "proxy:run": "powershell -ExecutionPolicy Bypass -File scripts/cfu.ps1 run",
    "sync:codex": "node scripts/sync-codex-chat.js",
    "service:start": "powershell -ExecutionPolicy Bypass -File scripts/cfu.ps1 service-start",
    "service:stop": "powershell -ExecutionPolicy Bypass -File scripts/cfu.ps1 service-stop",
    "service:status": "powershell -ExecutionPolicy Bypass -File scripts/cfu.ps1 service-status",
    "dev": "npm run dev:cli",
    "ui": "powershell -ExecutionPolicy Bypass -File scripts/cfu.ps1 ui",
    "global:link": "npm link",
    "global:unlink": "npm unlink -g codex-focus-ui",
    "ui:menu": "powershell -ExecutionPolicy Bypass -File scripts/cfu-control.ps1 menu"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "bin": {
    "cfu-ui": "scripts/cfu-ui.js"
  }
}

